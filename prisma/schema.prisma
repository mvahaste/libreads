generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator erd {
  provider                  = "prisma-erd-generator"
  disabled                  = true
  ignoreEnums               = true
  disableEmoji              = true
  includeRelationFromFields = true
  theme                     = "neutral"
}

datasource db {
  provider = "sqlite"
}

model Image {
  id        String   @id @default(uuid())
  mime      String
  data      Bytes
  createdAt DateTime @default(now())

  users User[]
  books Book[]

  @@map("image")
}
