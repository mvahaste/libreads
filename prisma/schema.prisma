generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator erd {
  provider                  = "prisma-erd-generator"
  ignoreEnums               = true
  disableEmoji              = true
  includeRelationFromFields = false
  ignorePattern             = "Session,Account,Verification"
  theme                     = "neutral"
}

datasource db {
  provider = "sqlite"
}

model Image {
  id        String   @id @default(uuid())
  mime      String
  data      Bytes
  createdAt DateTime @default(now())

  users User[]
  books Book[]

  @@map("image")
}
