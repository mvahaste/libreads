{
  "name": "libreads",
  "version": "0.1.0",
  "description": "A self-hosted reading tracker.",
  "author": "mvahaste",
  "license": "MIT",
  "repository": "https://github.com/mvahaste/libreads",
  "private": true,
  "scripts": {
    "dev": "next dev --experimental-https",
    "build": "prisma generate && next build",
    "start": "next start",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "format": "prettier --write -l . && prisma format",
    "format:check": "prettier -l .",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node --env-file=.env prisma/seed.mjs",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset",
    "db:check": "prisma validate",
    "type-check": "tsc --noEmit",
    "locale-check": "tsx validate-locales.ts",
    "check": "npm run lint:check && npm run type-check && npm run format:check && npm run db:check && npm run test && npm run locale-check ",
    "fix": "npm run lint && npm run format",
    "clean": "rm -rf .next node_modules"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^7.4.2",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@trpc/tanstack-react-query": "^11.11.0",
    "@zxing/browser": "^0.1.5",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lru-cache": "^11.2.6",
    "lucide-react": "^0.574.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "server-only": "^0.0.1",
    "slug": "^11.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lru-cache": "^7.10.9",
    "@types/node": "^20.19.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/slug": "^5.0.9",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.4.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
